# Обязательные
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
DATABASE_URL=your_neon_postgres_url

# LLM — выберите ОДНОГО провайдера:
# Вариант 1: Gemini (по умолчанию)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Вариант 2: Groq (бесплатный, быстрый — РЕКОМЕНДУЕТСЯ)
# Зарегистрируйтесь на https://console.groq.com и получите ключ
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_your_groq_key
# LLM_MODEL=llama-3.3-70b-versatile

# Вариант 3: OpenRouter (много бесплатных моделей)
# Зарегистрируйтесь на https://openrouter.ai и получите ключ
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-your_openrouter_key
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Опциональные
ADMIN_ID=0
WEBHOOK_URL=https://your-vercel-app.vercel.app/api/webhook
