{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/health",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/cron/daily",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/cron/checkin",
      "dest": "api/webhook.py"
    },
    {
      "src": "/api/cron/birthday",
      "dest": "api/webhook.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/checkin",
      "schedule": "0 15 */3 * *"
    },
    {
      "path": "/api/cron/birthday",
      "schedule": "0 9 * * *"
    }
  ]
}
